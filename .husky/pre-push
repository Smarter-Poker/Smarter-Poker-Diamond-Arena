#!/bin/sh
# ═══════════════════════════════════════════════════════════════════════════════
# PRE-PUSH SAFETY GATE — TypeScript Compilation Check (ADVISORY MODE)
# ═══════════════════════════════════════════════════════════════════════════════
# This repo has pre-existing TypeScript errors.
# The hook WARNS about them but does NOT block the push.
# Once all TS errors are fixed, remove the "exit 0" on the error branch
# and uncomment "exit 1" to switch to BLOCKING mode.
#
# To skip this check entirely: git push --no-verify
# ═══════════════════════════════════════════════════════════════════════════════

echo "🔒 Pre-push safety gate: Running TypeScript check..."

# Capture tsc output once (avoid double invocation)
TSC_OUTPUT=$(npx tsc --noEmit 2>&1)
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  TS_ERRORS=$(echo "$TSC_OUTPUT" | grep -c "error TS")
  echo ""
  echo "⚠️  TypeScript found $TS_ERRORS error(s) — ADVISORY WARNING"
  echo "   Push will continue (this repo has known pre-existing TS errors)."
  echo "   Fix these errors to upgrade to blocking mode."
  echo ""
  # ADVISORY: warn but allow push (change to "exit 1" once TS errors are fixed)
  exit 0
  # exit 1  # Uncomment this line to switch to BLOCKING mode
fi

echo "✅ TypeScript check passed — zero errors!"
exit 0
